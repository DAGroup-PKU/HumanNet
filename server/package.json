{
  "name": "ego-sites-server",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "Admin + content API for the Project Nebula landing page.",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "start": "node --enable-source-maps --import tsx src/index.ts",
    "seed": "tsx src/seed.ts",
    "oss:verify": "tsx scripts/oss-verify.ts",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "ali-oss": "^6.23.0",
    "bcryptjs": "^2.4.3",
    "better-sqlite3": "^11.5.0",
    "cors": "^2.8.5",
    "express": "^4.21.0",
    "express-rate-limit": "^7.4.1",
    "jsonwebtoken": "^9.0.2",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/ali-oss": "^6.23.3",
    "@types/bcryptjs": "^2.4.6",
    "@types/better-sqlite3": "^7.6.11",
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/jsonwebtoken": "^9.0.6",
    "@types/node": "^22.7.5",
    "tsx": "^4.19.0",
    "typescript": "^5.6.0"
  }
}
