# ══════════════════════════════════════════════════════════════════════
#  Project Nebula — environment variables
#  Copy to `.env` and edit. The file is gitignored. Both the Vite dev
#  server and the Express backend read from this single file.
# ══════════════════════════════════════════════════════════════════════

# ─── HTTP ─────────────────────────────────────────────────────────────
# Where the Express API listens. Vite proxies /api/* to this port.
SERVER_PORT=5175

# Browser origin allowed to hit /api/* directly (the dev Vite server).
# In production where the SPA and API share a host, this can be left as
# the public origin. Comma-separate for multiple.
CORS_ORIGIN=http://localhost:5174

# Optional: override the API target for the Vite dev proxy. The default
# is http://localhost:5175 which matches SERVER_PORT above.
# VITE_API_TARGET=http://localhost:5175

# ─── Database ─────────────────────────────────────────────────────────
# Path to the SQLite file. Defaults to ./server/data/nebula.db.
# DB_PATH=/var/lib/ego-sites/nebula.db

# ─── Auth (admin SPA / JWT) ───────────────────────────────────────────
# CRITICAL: change this to a strong random string in production. A
# leaked secret means anyone can mint admin tokens.
#   openssl rand -hex 64    # generates a good value
JWT_SECRET=replace-me-with-a-long-random-string

# Token lifetime in seconds (default 8 hours).
JWT_TTL_SECONDS=28800

# Bootstrap admin credentials. Used by `npm --prefix server run seed`.
# The password is bcrypt-hashed before being written to SQLite, so this
# var only matters at seed time, not at runtime. Re-run the seed to
# rotate the password.
ADMIN_USERNAME=admin
ADMIN_PASSWORD=change-me-on-first-deploy

# ─── Aliyun OSS (private video bucket) ────────────────────────────────
# When all four of REGION/BUCKET/ACCESS_KEY_ID/ACCESS_KEY_SECRET are set,
# any video stored as kind:"oss" is signed at request time using
# ali-oss's asyncSignatureUrl. Leave them blank to disable signing —
# kind:"oss" refs then fall back to a clearly-broken placeholder URL
# and a warning is logged at boot.
#
# RAM best practice: create a sub-account, attach an inline policy that
# only allows `oss:GetObject` on the single bucket, and use that AK/SK
# here. NEVER use the root Aliyun account credentials.
#
# OSS_REGION=oss-cn-beijing
# OSS_BUCKET=nebula-clips
# OSS_ACCESS_KEY_ID=LTAI...
# OSS_ACCESS_KEY_SECRET=...
#
# Optional: override the endpoint (e.g. internal endpoint when running
# inside Aliyun for free egress). When omitted the SDK derives one from
# OSS_REGION.
# OSS_ENDPOINT=oss-cn-beijing-internal.aliyuncs.com
#
# Lifetime of signed playback URLs (seconds). 1h is a reasonable default
# — long enough to watch the page, short enough that leaked links rot
# quickly.
# OSS_URL_TTL_SECONDS=3600
#
# Force HTTPS on signed URLs. Set to "false" only for local toy setups.
# OSS_SECURE=true

# ─── Public API rate limiter ──────────────────────────────────────────
# GET /api/config is the only public endpoint. The limiter caps it at
# `PUBLIC_API_RATE_LIMIT` requests per `PUBLIC_API_RATE_WINDOW_MS`
# milliseconds per client IP. Defaults: 60 req/min/IP — enough for a
# normal user reloading the page, harsh enough to slow down a script
# trying to harvest signed URLs.
# PUBLIC_API_RATE_LIMIT=60
# PUBLIC_API_RATE_WINDOW_MS=60000
