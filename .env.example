# Backend (server/) — copy to .env and fill in for production deploys.
# In dev, leaving this file absent works fine; the defaults below are used.

# Where the Express API listens. Vite proxies /api/* to this port.
SERVER_PORT=5175

# Path to the SQLite file. Defaults to ./server/data/nebula.db.
# DB_PATH=/var/lib/ego-sites/nebula.db

# CRITICAL: change this to a strong random string in production.
# A leaked secret means anyone can mint admin tokens.
JWT_SECRET=replace-me-with-a-long-random-string

# Token lifetime in seconds (default 8 hours).
JWT_TTL_SECONDS=28800

# Bootstrap admin credentials. Used by `npm run seed`. The password is
# bcrypt-hashed before being written to SQLite, so this var only matters
# at seed time, not at runtime. Re-run `npm run seed` to rotate.
ADMIN_USERNAME=admin
ADMIN_PASSWORD=change-me-on-first-deploy

# Browser origin allowed to hit /api/* directly (the dev Vite server).
# In production where the SPA and API share a host, this can be left as
# the public origin. Comma-separate for multiple.
CORS_ORIGIN=http://localhost:5174

# Optional: override the API target for the Vite dev proxy. The default
# is http://localhost:5175 which matches SERVER_PORT above.
# VITE_API_TARGET=http://localhost:5175
