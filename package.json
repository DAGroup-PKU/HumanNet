{
  "name": "ego-sites",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "description": "Embodied AI open-source dataset — responsive landing page",
  "scripts": {
    "dev": "concurrently --kill-others-on-fail --names \"web,api\" --prefix-colors \"yellow,cyan\" \"vite\" \"npm --prefix server run dev\"",
    "dev:web": "vite",
    "dev:api": "npm --prefix server run dev",
    "seed": "npm --prefix server run seed",
    "build": "tsc -b && vite build",
    "preview": "vite preview --host",
    "lint": "eslint . --ext .ts,.tsx"
  },
  "dependencies": {
    "@heroui/react": "^3.0.3",
    "@heroui/styles": "^3.0.3",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "react-router-dom": "^6.30.3"
  },
  "devDependencies": {
    "@tailwindcss/vite": "^4.0.0",
    "@types/node": "^22.19.17",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@vitejs/plugin-react": "^4.3.0",
    "concurrently": "^9.2.1",
    "tailwindcss": "^4.0.0",
    "typescript": "^5.6.0",
    "vite": "^7.0.0"
  }
}
